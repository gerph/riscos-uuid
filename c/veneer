void *module_private;

/***************************************************************************
 * Function:     Mod_Init
 * Description:  Initialise the module, setting up vectors, callbacks and
 *               any other parts of the system necessary for the module to
 *               function.
 * Parameters:   tail        = pointer to command line (control terminated)
 *               podule_base = address of podule module was started from, or
 *                             NULL if none
 *               pw          = private word for module
 * On exit:      Return NULL for successful initialisation, or a pointer to
 *               an error block if the module could not start properly.
 **************************************************************************/
_kernel_oserror *Mod_Init(const char *tail, int podule_base, void *pw)
{
  module_private = pw;
  loadstate();
  var_init(pw);
  return NULL;
}


/***************************************************************************
 * Function:     Mod_Final
 * Description:  Finalise the module, shutting down any systems necessary,
 *               freeing vectors and releasing workspace
 * Parameters:   fatal       = fatality indicator; 1 if fatal, 0 if
 *                             reinitialising
 *               podule_base = address of podule module was started from, or
 *                             NULL if none
 *               pw          = private word for module
 * On exit:      Return 0 for successful finalisation, or a pointer to an
 *               error block if module was not shutdown properly.
 **************************************************************************/
_kernel_oserror *Mod_Final(int fatal, int podule_base, void *pw)
{
  var_final(pw);
  /* Before we exit, write out our state */
  savestate(NULL, pw); /* The registers and private word are not used */
  return NULL;
}

#define URN_UUID_STR "urn:uuid:"
#define URN_UUID_LEN (sizeof(URN_UUID_STR)-1)

/*************************************************** Gerph *********
 Function:     convert
 Description:  Convert from one representation to another
 Parameters:   inrep = the input representation type
               input-> the input data
               outrep = the output representation type
               output-> the output data
 Returns:      pointer to error, or NULL if ok
 ******************************************************************/
_kernel_oserror *convert(int inrep, const char *input,
                         int outrep, char *output)
{
  uuid_upnp bin;
  /* First convert to a binary form from the input form */
  switch (inrep)
  {
    case UUID_Representation_Binary:
      /* Nothing to do */
      memcpy(&bin, input, sizeof(bin));
      break;

    case UUID_Representation_URN:
      {
        const char *against = URN_UUID_STR;
        for (; *against!='\0'; against++, input++)
          if (tolower(*input)!=*against)
            return err_InvalidURN;
        /* Note: No escaping in RFC2141 namespace identifier (section 2.1)
                 or scheme identifier, so we don't need any % escape
                 processing */
      }
      /* Fall through to the string processor */

    case UUID_Representation_String:
      /* The string processor is a simple process, complicated by the
         fact that I've bundled in the URN processor in the same routine
         which means we must process escaped characters as well as the
         regular string format. */
      {
        int hi_nibble = 1;
        char *bindata = (char *)&bin;
        int i;
        _kernel_oserror *err = (inrep == UUID_Representation_String) ?
                                     err_InvalidString : err_InvalidURN;
        for (i=0; input[i]!='\0'; i++)
        {
          int c=input[i];
          /* Example:
                         11111111112222222222333333
               012345678901234567890123456789012345
               f81d4fae-7dec-11d0-a765-00a0c91e6bf6
           */
          if (input[i] == '%' && inrep == UUID_Representation_URN)
          {
            int d;
            /* Escaped input (RFC2141, section 2.2) */

            /* Increment input so that the i variable is still the same
               offset within the string; then process the first nibble. */
            input++;
            c=input[i];
                 if (c>='A' && c<='F') d=(c-'A'+10)<<4;
            else if (c>='a' && c<='f') d=(c-'a'+10)<<4;
            else if (c>='0' && c<='9') d=(c-'0')<<4;
            else return err;

            /* Again, an increment of the input and the second nibble. */
            input++;
            c=input[i];
                 if (c>='A' && c<='F') d|=(c-'A'+10)<<0;
            else if (c>='a' && c<='f') d|=(c-'a'+10)<<0;
            else if (c>='0' && c<='9') d|=(c-'0')<<0;
            else return err;

            c=d;
          }
          if (i==8 || i==13 || i==18 || i==23)
          {
            if (input[i] != '-')
              return err;
          }
          else
          {
            /* We have a nibble of the data for the binary block; write
               it in. */
                 if (c>='A' && c<='F') c=(c-'A'+10);
            else if (c>='a' && c<='f') c=(c-'a'+10);
            else if (c>='0' && c<='9') c=(c-'0');
            else return err;

            if (hi_nibble) *bindata    = c<<4;
            else           *bindata++ |= c;
            hi_nibble ^= 1;
          }
        }
        if (i != 36)
          return err;

        /* Finally, fix up the fields that are bigendian */
        bin.time_low = htonl(bin.time_low);
        bin.time_mid = htons(bin.time_mid);
        bin.time_hi_and_version = htons(bin.time_hi_and_version);
      }
      break;
  }

  /* Now convert from binary format to output representation */
  switch (outrep)
  {
    case UUID_Representation_Binary:
      memcpy(output, &bin, sizeof(bin));
      break;

    case UUID_Representation_String:
      uuid_unpack(&bin, output);
      break;

    case UUID_Representation_URN:
      memcpy(output, URN_UUID_STR, URN_UUID_LEN);
      uuid_unpack(&bin, output+URN_UUID_LEN);
      break;

    default:
      return err_InvalidRepresentation;
  }
  return NULL;
}

/***************************************************************************
 * Description:  SWI handler routine. All SWIs for this module will be
 *               passed to these routines.
 * Parameters:   number = SWI number within SWI chunk (i.e. 0 to 63)
 *               r      = pointer to register block on entry
 *               pw     = private word for module
 * On exit:      Return NULL if SWI handled sucessfully, setting return
 *               register values (r0-r9) in r.
 *               Return error_BAD_SWI for out of range SWIs.
 *               Return an error block for a custom error.
 **************************************************************************/
_kernel_oserror *SWI_Convert(int number, _kernel_swi_regs *r, void *pw)
{
  /* UUID_Convert
     => R0 = input representation
        R1-> input data
        R2 = output representation
        R3-> output data

     Intentionally the same interface as MimeMap.
   */
  int inrep         = r->r[0];
  const char *inbuf = (const char *)r->r[1];
  int outrep        = r->r[2];
  char *outbuf      = (char *)r->r[3];
  return convert(inrep, inbuf, outrep, outbuf);
}

/***************************************************************************
 * Description:  SWI handler routine. All SWIs for this module will be
 *               passed to these routines.
 * Parameters:   number = SWI number within SWI chunk (i.e. 0 to 63)
 *               r      = pointer to register block on entry
 *               pw     = private word for module
 * On exit:      Return NULL if SWI handled sucessfully, setting return
 *               register values (r0-r9) in r.
 *               Return error_BAD_SWI for out of range SWIs.
 *               Return an error block for a custom error.
 **************************************************************************/
_kernel_oserror *SWI_Create(int number, _kernel_swi_regs *r, void *pw)
{
  /* UUID_Create - create a UUID
     => R0 = flags:
               b0-3: Output representation
               b4-7: Version to create
        R1-> the block to fill in with the result
        R2-> namespace to use as base (a UUID block)
        R3-> name to use (for version 3, 5)
        R4 = length of name, or 0 if the name is a 0-terminated string (for
             version 3, 5)
   */
  unsigned long flags = (unsigned long)r->r[0];
  char *fillin = (char *)r->r[1];
  uuid_upnp uuid;

  unsigned long representation = (flags & UUID_Representation_MASK);
  unsigned long version        = (flags & UUID_Version_MASK);

  switch (version)
  {
    case UUID_Version_Time:
      if (!uuid_create(&uuid))
        return err_CantGenerate;
      break;

    case UUID_Version_NameMD5:
    case UUID_Version_NameSHA1:
      {
        uuid_upnp *base = (uuid_upnp *)r->r[2];
        const char *name = (const char *)r->r[3];
        int namelen = r->r[4];
        if (r->r[4] == 0)
          namelen = strlen(name);
        if (r->r[4] < 0)
          return err_InvalidNameLength;
        if (version == UUID_Version_NameMD5)
          uuid_create_md5_from_name(&uuid, *base, name, namelen);
        /* else */
          /* uuid_create_sha1_from_name(&uuid, *base, name, namelen); */
      }
      break;


    case UUID_Version_DCESecurity:
    case UUID_Version_Random:
    default:
      return err_InvalidVersion;
  }

  return convert(UUID_Representation_Binary, (void*)&uuid,
                 representation, fillin);
}

/***************************************************************************
 * Description:  SWI handler routine. All SWIs for this module will be
 *               passed to these routines.
 * Parameters:   number = SWI number within SWI chunk (i.e. 0 to 63)
 *               r      = pointer to register block on entry
 *               pw     = private word for module
 * On exit:      Return NULL if SWI handled sucessfully, setting return
 *               register values (r0-r9) in r.
 *               Return error_BAD_SWI for out of range SWIs.
 *               Return an error block for a custom error.
 **************************************************************************/
_kernel_oserror *SWI_Compare(int number, _kernel_swi_regs *r, void *pw)
{
  /* UUID_Compare
     => R0 = first representation
        R1-> first data
        R2 = second representation
        R3-> second data
     <= R0 = -1, 0, +1 based on input data

     Intentionally the same interface as MimeMap.
   */
  int firstrep       = r->r[0];
  void *first        = (void *)r->r[1];
  int secondrep      = r->r[2];
  void *second       = (void *)r->r[3];
  uuid_upnp firstuuid, seconduuid;
  _kernel_oserror *err;

  err = convert(firstrep, first, UUID_Representation_Binary, (char *)&firstuuid);
  if (err) return err;
  err = convert(secondrep, second, UUID_Representation_Binary, (char *)&seconduuid);
  if (err) return err;

  r->r[0] = uuid_compare(&firstuuid, &seconduuid);
  return NULL;
}
