/*-----------------------------------------------------------------------------*/
void
get_system_time( uuid_time_t * uuid_time )
{
#ifndef __riscos
    struct timeval tp;

    gettimeofday( &tp, ( struct timezone * )0 );

    /*
       Offset between UUID formatted times and Unix formatted times.
       UUID UTC base time is October 15, 1582.
       Unix base time is January 1, 1970.
     */
    *uuid_time = ( tp.tv_sec * 10000000 ) + ( tp.tv_usec * 10 ) +
        I64( 0x01B21DD213814000 );
#else
    /* FIXME:  Lie. Lots. */
    unsigned long words[2];
    ulonglong_t num, mult, adjust, csperday;
    words[0] = 3; /* Read 5 byte time */
    words[1] = 0;
    _swix(OS_Word, _INR(0,1), 14, &words);
    num.lo = words[0];
    num.hi = words[1];
    /* num now contains the number of cs since 1 Jan 1900, which we need
       to translate to nanoseconds since Oct 15 1582.
       There are 77 days from 15 Oct 1582 to 1 Jan 1583 - 30 days in
       November, 31 in December, and 16 left over from the 31 days in
       October.
       Leap years occur every 4 years for the intervening years, starting
       at 1584, which gives us 78 leap years.
       However, leap years do not occur on years divisible by 100 unless it
       is also divisible by 400, which gives us no leap years in 1700 and
       1800, so we only have 76 leap years.
       There are 365 days in a year, and 317 years between 1583 and 1900.
       365 days * 317 = 115705 days.
       plus 78 leap days = 115783
       plus 78 days to end of year = 115861
     */
    LL_UI2L(adjust, 365*317+77+78);   /* The above calculation */
    LL_UI2L(csperday, 100*60*60*24);
    LL_MUL(adjust, adjust, csperday); /* The adjustment in cs */
    LL_ADD(num, num, adjust);         /* number of cs since 15 Oct 1582 */
    LL_UI2L(mult, 10000000/100);      /* 100 nanoseconds in a cs */
    LL_MUL(num, num, mult);           /* Yay, number of 100ns ticks since ... */

    uuid_time->hi = num.hi;
    uuid_time->lo = num.lo;
#endif
}

/*-----------------------------------------------------------------------------*/
void
get_random_info( char seed[16] )
{
    MD5_CTX c;
    char *hn;
    typedef struct {
        unsigned long monotime;
        unsigned long fivebyte[2];
        char hostname[256];
    } randomness;
    randomness r;

    MD5Init( &c );

    /* FIXME: Insert randomness */
    _swix(OS_ReadMonotonicTime, _OUT(0), &r.monotime);
    r.fivebyte[0] = 3; /* Time as 5 bytes value */
    _swix(OS_Word, _INR(0,1), 14, &r.fivebyte);
    hn = getenv("Inet$Hostname");
    if (hn==NULL)
    { /* Nothing, we get random stack data, which is probably ok */}
    else
      strncpy(r.hostname, hn, 256);

    MD5Update( &c, (unsigned char *)&r, sizeof( randomness ) );
    MD5Final( (unsigned char *)seed, &c );
}

