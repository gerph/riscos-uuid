#define ntohl(x) (   ( ((unsigned long)(x))>>24 ) | \
                   ( ( ((unsigned long)(x))>>8 ) & 0x0000FF00 ) | \
                   ( ( ((unsigned long)(x))<<8 ) & 0x00FF0000 ) | \
                     ( ((unsigned long)(x))<<24) )
#define ntohs(x) ( ( ( ((unsigned short)(x))>>8 ) & 0x00FF ) | \
                   ( ( ((unsigned short)(x))<<8 ) & 0xFF00 ) )

#define htonl(x) ntohl(x)
#define htons(x) ntohs(x)

