#ifndef UUID_H
#define UUID_H

/* SWI numbers */
/* SWIs here */

/* Flags for SWI UUID_Create */
#define UUID_Representation_Binary (0<<0) /* Binary block (16 bytes) */
#define UUID_Representation_String (1<<0) /* Regular string (37 bytes) */
#define UUID_Representation_URN    (2<<0) /* RFC4122 URN string (46 bytes) */
#define UUID_Representation_MASK   (15<<0)

#define UUID_Version_Time          (1<<4)
#define UUID_Version_DCESecurity   (2<<4) /* Not generated by UUID module */
#define UUID_Version_NameMD5       (3<<4)
#define UUID_Version_Random        (4<<4) /* Not generated by UUID module */
#define UUID_Version_NameSHA1      (5<<4)
#define UUID_Version_MASK          (15<<4)

#endif
